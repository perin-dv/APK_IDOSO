<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <!-- Home Fragment -->
    <fragment
        android:id="@+id/navigation_home"
        android:name="com.mesawa.cuidarproximo.ui.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/activity_home" />

    <!-- Dashboard Fragment -->
    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.mesawa.cuidarproximo.ui.dashboard.DashboardFragment"
        android:label="@string/title_dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <!-- Notifications Fragment -->
    <fragment
        android:id="@+id/navigation_notifications"
        android:name="com.mesawa.cuidarproximo.ui.notifications.NotificationsFragment"
        android:label="@string/title_notifications"
        tools:layout="@layout/fragment_notifications" />

    <!-- SOS Fragment -->
    <fragment
        android:id="@+id/navigation_sos"
        android:name="com.mesawa.cuidarproximo.ui.sos.SosFragment"
        android:label="SOS Emergência"
        tools:layout="@layout/fragment_sos" />




    <!-- Pagamento Activity -->
    <fragment
        android:id="@+id/navigation_pagamento"
        android:name="com.mesawa.cuidarproximo.ui.pagamento.PagamentoActivity"
        android:label="Pagamento"
        tools:layout="@layout/activity_pagamento" />

    <!-- Medicamentos Fragment -->
    <fragment
        android:id="@+id/navigation_medicamentos"
        android:name="com.mesawa.cuidarproximo.ui.medicamentos.MedicamentosActivity"
        android:label="Medicamentos"
        tools:layout="@layout/activity_medicamentos" />

</navigation>