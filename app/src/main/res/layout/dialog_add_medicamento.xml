<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F9FAFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TITULO -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💊 Novo medicamento"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#111827"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Adicione os dados do medicamento"
            android:textColor="#6B7280"
            android:textSize="14sp"/>

        <!-- NOME -->

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:boxBackgroundMode="filled"
            app:boxCornerRadiusTopStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusBottomEnd="18dp"
            app:boxBackgroundColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editNomeMedicamento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nome medicamento"
                android:padding="16dp"
                android:textColor="#111827"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- DOSAGEM -->

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:boxBackgroundMode="filled"
            app:boxCornerRadiusTopStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusBottomEnd="18dp"
            app:boxBackgroundColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editDosagemMedicamento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Dosagem (50mg)"
                android:padding="16dp"
                android:textColor="#111827"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- HORARIO -->

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:boxBackgroundMode="filled"
            app:boxCornerRadiusTopStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusBottomEnd="18dp"
            app:boxBackgroundColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editHorarioMedicamento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Horário (08:00)"
                android:padding="16dp"
                android:textColor="#111827"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- OBS -->

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:boxBackgroundMode="filled"
            app:boxCornerRadiusTopStart="18dp"
            app:boxCornerRadiusTopEnd="18dp"
            app:boxCornerRadiusBottomStart="18dp"
            app:boxCornerRadiusBottomEnd="18dp"
            app:boxBackgroundColor="#FFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editObsMedicamento"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="top"
                android:hint="Observações"
                android:padding="16dp"
                android:textColor="#111827"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- BOTAO -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalvarMedicamento"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="28dp"
            android:text="Salvar medicamento"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#2563EB"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_check"
            app:iconGravity="textStart"
            app:iconPadding="12dp"/>

    </LinearLayout>

</ScrollView>