<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITULO -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚨 SOS Emergência"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#B91C1C"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contatos prioritários para emergência"
            android:textSize="15sp"
            android:textColor="#6B7280"
            android:layout_marginTop="6dp"/>

        <!-- BOTAO SOS -->

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSOSPrincipal"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="#DC2626"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SOS"
                    android:textColor="#FFFFFF"
                    android:textSize="52sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Toque para emergência"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardContatosSOS"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="8dp"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"

                android:background="@drawable/bg_contatos_sos_gradient"
                android:gravity="center_vertical">

                <!-- Ícone SOS -->
                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_sos_alert"
                    android:contentDescription="SOS"
                    android:background="@drawable/circle_red"
                    android:padding="12dp"/>

                <!-- Texto principal -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/txtSOSLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contatos de Emergência"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/txtSOSDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clique para gerenciar e avisar familiares"
                        android:textColor="#E0E0E0"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <!-- Seta direita -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#FFFFFF" />
            </LinearLayout>

        </androidx.cardview.widget.CardView>
        <!-- CONTATO 1 -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contatos emergência"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editNomeSOS"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nome contato"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTelefoneSOS"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Telefone"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalvarSOS"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="24dp"
            android:text="Salvar contato SOS"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#DC2626"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_check"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:rippleColor="#FFFFFF"/>


    </LinearLayout>


</ScrollView>