<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- HEADER -->

    <LinearLayout
        android:id="@+id/headerMedicamentos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="32dp"
        android:paddingEnd="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💊 Medicamentos"
            android:textColor="#111827"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Gerencie os medicamentos do idoso"
            android:textColor="#6B7280"
            android:textSize="15sp"/>

    </LinearLayout>

    <!-- CARD STATUS -->

    <androidx.cardview.widget.CardView
        android:id="@+id/cardResumo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerMedicamentos"
        android:layout_marginStart="20dp"
        android:layout_marginTop="22dp"
        android:layout_marginEnd="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#2563EB">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monitoramento ativo"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Lembretes e horários funcionando"
                    android:textColor="#DBEAFE"
                    android:textSize="14sp"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💊"
                android:textSize="42sp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- LISTA -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMedicamentos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/cardResumo"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="100dp"/>

    <!-- BOTAO FLOAT -->

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAddMedicamento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="22dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="#2563EB"
        app:elevation="8dp"
        app:maxImageSize="28dp"
        app:tint="#FFFFFF"/>

</RelativeLayout>