<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardAgenda"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- TOPO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtHora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:00"
                android:textColor="#2563EB"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCategoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/circle_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Remédio"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- TITULO -->
        <TextView
            android:id="@+id/txtTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Tomar pressão"
            android:textColor="#111827"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- DESCRIÇÃO -->
        <TextView
            android:id="@+id/txtDescricao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Remédio após café"
            android:textColor="#6B7280"
            android:textSize="15sp" />

        <!-- PRIORIDADE -->
        <TextView
            android:id="@+id/txtPrioridade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Alta prioridade"
            android:textColor="#DC2626"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAtrasado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="⚠️ ATRASADO"
            android:textColor="#DC2626"
            android:textStyle="bold"
            android:textSize="13sp"
            android:visibility="gone"/>

        <!-- CHECK -->
        <CheckBox
            android:id="@+id/checkConcluido"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Concluído"
            android:textColor="#111827"
            android:textStyle="bold"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>